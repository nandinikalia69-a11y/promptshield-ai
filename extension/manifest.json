{
  "manifest_version": 3,
  "name": "PromptShield AI",
  "version": "1.0.0",
  "description": "Zero-Trust AI Protection for Generative AI. Detect and redact sensitive data before it reaches ChatGPT, Claude, Gemini, and more.",
  "icons": {
    "16":  "assets/icons/icon16.png",
    "32":  "assets/icons/icon32.png",
    "48":  "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/icons/icon16.png",
      "32":  "assets/icons/icon32.png",
      "48":  "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "PromptShield AI"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://bard.google.com/*",
        "http://localhost:3000/*"
      ],
      "js": [
        "engine/detectionEngine.js",
        "engine/riskEngine.js",
        "engine/redactionEngine.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://www.perplexity.ai/*",
    "https://copilot.microsoft.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "popup/*",
        "dashboard/*",
        "storage/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
